    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^8.1.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "fast-xml-parser": "^5.5.1",
    "he": "^1.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
